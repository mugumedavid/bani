---

<Base title="Community" description="Join the Bani community. Connect with other users, contribute code, and help shape the future of database migrations.">
  <section class="section-padding bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-950">
    <div class="container-narrow text-center">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-white">
        Community
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
        Bani is built in the open. Join the community to get help, share ideas, and contribute.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white dark:bg-slate-950">
    <div class="container-wide">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {resources.map((resource) => (
          <a
            href={resource.href}
            class="group block rounded-xl border border-slate-200 dark:border-slate-800 p-8 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-lg transition-all"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="mb-4 text-slate-400 dark:text-slate-500 group-hover:text-brand-500 dark:group-hover:text-brand-400 transition-colors">
              <Fragment set:html={resource.icon} />
            </div>
            <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-2">{resource.title}</h2>
            <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">{resource.description}</p>
            <span class="text-sm font-medium text-brand-600 dark:text-brand-400 group-hover:text-brand-700 dark:group-hover:text-brand-300">
              {resource.cta} &rarr;
            </span>
          </a>
        ))}
      </div>

      <!-- Ways to contribute -->
      <div class="mt-16 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-8 md:p-12">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6 text-center">
          Ways to contribute
        </h2>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
          {[
            { title: 'Report bugs', description: 'Found something broken? Open a GitHub issue with reproduction steps.' },
            { title: 'Write code', description: 'Fix bugs, add features, or build community connectors.' },
            { title: 'Improve docs', description: 'Spot a typo? Missing a guide? Documentation PRs are always welcome.' },
            { title: 'Spread the word', description: 'Star the repo, write a blog post, or tell a colleague about Bani.' },
          ].map((way) => (
            <div class="text-center">
              <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-2">{way.title}</h3>
              <p class="text-sm text-slate-500 dark:text-slate-400">{way.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>

---

<section class="section-padding bg-white dark:bg-slate-950">
  <div class="container-wide">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 dark:text-white">
        Join the community
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
        Bani is open source and community-driven. Get involved, ask questions, and help shape the future of database migrations.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {links.map((link) => (
        <a
          href={link.href}
          class="group block rounded-xl border border-slate-200 dark:border-slate-800 p-6 hover:border-brand-300 dark:hover:border-brand-700 hover:shadow-lg transition-all"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="mb-4 inline-flex items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800 p-2.5 text-slate-600 dark:text-slate-300 group-hover:bg-brand-50 dark:group-hover:bg-brand-900/30 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
            <Fragment set:html={link.icon} />
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2">{link.title}</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">{link.description}</p>
          <span class="text-sm font-medium text-brand-600 dark:text-brand-400 group-hover:text-brand-700 dark:group-hover:text-brand-300">
            {link.cta} &rarr;
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
